{
  "name": "edgestat-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "generate:openapi": "tsx ../../scripts/generate-openapi.ts && openapi-typescript src/api/openapi.json -o src/api/schema.d.ts",
    "lint": "eslint src"
  },
  "dependencies": {
    "@edgestat/schemas": "*",
    "@tanstack/react-query": "^5.96.2",
    "clsx": "^2.1.1",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.14.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.3"
  }
}
