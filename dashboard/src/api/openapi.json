{
  "openapi": "3.1.0",
  "info": {
    "title": "EdgeStat API",
    "version": "0.1.0",
    "description": "Privacy-first analytics engine on Cloudflare. Analytics at the edge. Owned by you."
  },
  "servers": [
    {
      "url": "/",
      "description": "Current deployment"
    }
