  "components": {
    "schemas": {
      "IngestBody": {
        "type": "object",
        "properties": {
          "site_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "events": {
            "minItems": 1,
            "maxItems": 20,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SingleEvent"
            }
          }
        },
        "required": ["site_id", "events"],
        "additionalProperties": false,
        "description": "Batch of events to ingest"
      },
      "SingleEvent": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["pageview", "session_start", "session_end", "custom", "web_vital"]
          },
          "url": {
            "type": "string",
            "maxLength": 2048
          },
          "referrer": {
            "type": "string",
            "maxLength": 2048
          },
          "utm_source": {
            "type": "string",
            "maxLength": 256
          },
          "utm_medium": {
            "type": "string",
            "maxLength": 256
          },
          "utm_campaign": {
            "type": "string",
            "maxLength": 256
          },
          "screen_width": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "screen_height": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "event_name": {
            "type": "string",
            "maxLength": 128
          },
          "event_props": {
            "type": "object",
            "propertyNames": {
              "type": "string",
              "maxLength": 64
            },
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "string",
                  "maxLength": 256
                },
                {
                  "type": "number"
                }
              ]
            }
          },
          "vital_name": {
            "type": "string",
            "enum": ["FCP", "LCP", "CLS", "FID", "INP", "TTFB"]
          },
          "vital_value": {
            "type": "number"
          },
          "timestamp": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          }
        },
        "required": ["type"],
        "additionalProperties": false,
        "description": "A single analytics event"
      },
      "CreateSiteBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "domain": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "required": ["name", "domain"],
        "additionalProperties": false
      },
      "CreateFunnelBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "steps": {
            "minItems": 2,
            "maxItems": 10,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 128
                },
                "type": {
                  "type": "string",
                  "enum": ["url", "event"]
                },
                "value": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 512
                }
              },
              "required": ["name", "type", "value"],
              "additionalProperties": false
            }
          }
        },
        "required": ["name", "steps"],
        "additionalProperties": false
      },
      "IngestResponse": {
        "type": "object",
        "properties": {
          "queued": {
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991
          }
        },
        "required": ["queued"],
        "additionalProperties": false
      },
      "ValidationErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "const": "validation_failed"
          },
          "status": {
            "type": "number",
            "const": 400
          },
          "issues": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                },
                "code": {
                  "type": "string"
                }
              },
              "required": ["path", "message", "code"],
              "additionalProperties": false
            }
          }
        },
        "required": ["error", "status", "issues"],
        "additionalProperties": false
      },
      "NotFoundErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "const": "not_found"
          },
          "status": {
            "type": "number",
            "const": 404
          },
          "resource": {
            "type": "string"
          }
        },
        "required": ["error", "status"],
        "additionalProperties": false
      },
      "ServerErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "const": "internal_server_error"
          },
          "status": {
            "type": "number",
            "const": 500
          }
        },
        "required": ["error", "status"],
        "additionalProperties": false
      },
      "ListSitesResponse": {
        "type": "object",
        "properties": {
          "sites": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Site"
            }
          }
        },
        "required": ["sites"],
        "additionalProperties": false
      },
      "Site": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "api_key": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          }
        },
        "required": ["id", "name", "domain", "api_key", "created_at"],
        "additionalProperties": false
      },
      "UnauthorizedErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "const": "unauthorized"
          },
          "status": {
            "type": "number",
            "const": 401
          }
        },
        "required": ["error", "status"],
        "additionalProperties": false
      },
      "CreateSiteResponse": {
        "type": "object",
        "properties": {
          "site": {
            "$ref": "#/components/schemas/Site"
          },
          "snippet": {
            "type": "string"
          }
        },
        "required": ["site", "snippet"],
        "additionalProperties": false
      },
      "StatsResponse": {
        "type": "object",
        "properties": {
          "visitors": {
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991
          },
          "pageviews": {
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991
          },
          "sessions": {
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991
          },
          "bounce_rate": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "avg_session_duration": {
            "type": "number"
          },
          "visitors_change": {
            "type": "number"
          },
          "pageviews_change": {
            "type": "number"
          }
        },
        "required": [
          "visitors",
          "pageviews",
          "sessions",
          "bounce_rate",
          "avg_session_duration",
          "visitors_change",
          "pageviews_change"
        ],
        "additionalProperties": false
      },
      "TimeseriesResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TimeseriesPoint"
            }
          }
        },
        "required": ["data"],
        "additionalProperties": false
      },
      "TimeseriesPoint": {
        "type": "object",
        "properties": {
          "bucket": {
            "type": "string"
          },
          "visitors": {
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991
          },
          "pageviews": {
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991
          }
        },
