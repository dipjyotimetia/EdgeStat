{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "generate:openapi": {
      "dependsOn": ["^build"],
      "inputs": ["../packages/schemas/src/**", "../scripts/generate-openapi.ts"],
      "outputs": ["src/api/openapi.json", "src/api/schema.d.ts"],
      "cache": true
    },
    "build": {
      "dependsOn": ["generate:openapi", "^build"],
      "outputs": ["dist/**", "tsconfig.tsbuildinfo"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": [],
      "cache": true
    }
  }
}
