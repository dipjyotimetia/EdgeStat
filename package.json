{
  "name": "edgestat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "build": "npm run generate:openapi && npm run build:dashboard && npm run build:snippet && cp public/s.js dashboard/dist/s.js",
    "build:dashboard": "cd dashboard && npm run build",
    "build:snippet": "cd sdk && npm run build",
    "generate:openapi": "npx tsx scripts/generate-openapi.ts && cd dashboard && npx openapi-typescript src/api/openapi.json -o src/api/schema.d.ts",
    "db:migrate": "wrangler d1 migrations apply edgestat-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply edgestat-db --remote",
    "types": "wrangler types",
    "typecheck": "tsc --noEmit",
    "setup": "npx tsx cli/src/index.ts setup"
  },
  "dependencies": {
    "itty-router": "^5.0.23",
    "openapi-fetch": "^0.17.0",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.1",
    "typescript": "^5",
    "wrangler": "^4"
  }
}
