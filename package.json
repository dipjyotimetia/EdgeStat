{
  "name": "edgestat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/schemas",
    "dashboard",
    "sdk",
    "cli"
  ],
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "build": "turbo run build --filter=edgestat-dashboard --filter=edgestat-sdk",
    "build:dashboard": "turbo run build --filter=edgestat-dashboard",
    "build:snippet": "turbo run build --filter=edgestat-sdk",
    "generate:openapi": "turbo run generate:openapi --filter=edgestat-dashboard",
    "check:schema": "npm run generate:openapi && git diff --exit-code dashboard/src/api/schema.d.ts dashboard/src/api/openapi.json",
    "db:migrate": "wrangler d1 migrations apply edgestat-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply edgestat-db --remote",
    "types": "wrangler types",
    "typecheck": "turbo run typecheck",
    "setup": "npm run build --workspace cli && node cli/dist/index.js setup"
  },
  "dependencies": {
    "@edgestat/schemas": "*",
    "itty-router": "^5.0.23",
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.1",
    "turbo": "^2.9.4",
    "typescript": "^5",
    "wrangler": "^4"
  }
}
